#!/bin/sh
# POST /cgi-bin/blockcheck1 → {ok, job_id} | {ok:false, error_b64}
# Аналог /cgi-bin/blockcheck2, но для nfqws v1 (zapret первый):
#   - другой STATE_DIR (можно гонять одновременно с blockcheck2)
#   - другой пул src-портов / queue numbers / nft-таблицы / mark
#   - бинарник nfqws вместо nfqws2
#   - другой gen-strategies (синтаксис v1)
# Сам runner и lib.sh переиспользованы из blockcheck2 — они полностью
# параметризованы через BC_* env vars.

echo "Content-Type: application/json; charset=utf-8"
echo ""

err() {
  msg="$1"
  printf '{"ok":false,"error_b64":"%s"}\n' \
    "$(printf '%s' "$msg" | base64 -w0 2>/dev/null || printf '%s' "$msg" | base64 | tr -d '\n')"
  exit 0
}

[ "$REQUEST_METHOD" = "POST" ] || err "POST required"

MAX_BODY=1048576
case "$CONTENT_LENGTH" in
  ''|*[!0-9]*) CONTENT_LENGTH=0 ;;
esac
[ "$CONTENT_LENGTH" -gt "$MAX_BODY" ] && err "request body too large"

body=$(head -c "$CONTENT_LENGTH")

extract_field() {
  printf '%s' "$body" | awk -F'&' -v key="$1" '{
    for(i=1;i<=NF;i++) {
      n=length(key)+1
      if (substr($i,1,n) == key"=") { print substr($i,n+1); exit }
    }
  }'
}
urldecode() {
  printf '%s\n' "$1" | sed 's/+/ /g; s/%\([0-9A-Fa-f][0-9A-Fa-f]\)/\\\x\1/g' | \
    while IFS= read -r line; do printf '%b' "$line"; done
}

domains_b64=$(urldecode "$(extract_field domains_b64)")
workers=$(extract_field workers)
tests=$(urldecode "$(extract_field tests)")
strats_b64=$(urldecode "$(extract_field strategies_b64)")
level=$(extract_field level)
fakebin=$(extract_field fakebin)
hard_min_kb=$(extract_field hard_min_kb)
rnd_repeats=$(extract_field rnd_repeats)

[ -z "$domains_b64" ] && err "domains_b64 required"
case "$workers" in
  ''|*[!0-9]*) workers=8 ;;
esac
[ "$workers" -lt 1 ]  && workers=1
[ "$workers" -gt 32 ] && workers=32
[ -z "$tests" ] && tests="http,tls12,tls13"
case "$tests" in
  *[!a-z0-9,]*) err "tests contains invalid chars" ;;
esac

# === Константы, отличающие BC1 от BC2 ===
# Каждый параметр должен НЕ пересекаться с BC2, чтобы оба сканера могли
# работать одновременно: разные nft-таблицы, queue-номера, src-port range,
# state-dir. Бинарник nfqws (v1) другой.
STATE_DIR=/dev/shm/mihomo-blockcheck1
BC1_NFT_TABLE=mihomo_blockcheck1
BC1_QUEUE_BASE=800
BC1_MARK_BASE=0x80000
BC1_SPORT_BASE=18000
BC1_NFQWS=nfqws

mkdir -p "$STATE_DIR" || err "cannot mkdir $STATE_DIR"

# GC: 5 последних завершённых + все running.
{
  for d in "$STATE_DIR"/*; do
    [ -d "$d" ] || continue
    name=$(basename "$d")
    ts="${name%%-*}"
    case "$ts" in ''|*[!0-9]*) continue ;; esac
    st=$(cat "$d/status" 2>/dev/null)
    printf '%s\t%s\t%s\n' "$ts" "$st" "$d"
  done
} | sort -rn | awk -F'\t' '
  $2 == "running" { next }
  { kept++; if (kept > 5) print $3 }
' | while IFS= read -r victim; do
  [ -n "$victim" ] || continue
  case "$victim" in
    "$STATE_DIR"/*-*) rm -rf "$victim" ;;
  esac
done

BC_DIR="${BC_DIR:-/www/blockcheck1}"
BC_RUN_DIR="${BC_RUN_DIR:-/www/blockcheck2}"
[ -f "$BC_RUN_DIR/run" ]          || err "$BC_RUN_DIR/run not found"
[ -r "$BC_RUN_DIR/lib.sh" ]       || err "$BC_RUN_DIR/lib.sh not found"
[ -f "$BC_DIR/strategies.list" ]  || err "$BC_DIR/strategies.list not found"
command -v nft     >/dev/null 2>&1 || err "nft не найден — фича работает только на RouterOS arm64/amd64 7.21+"
command -v openssl >/dev/null 2>&1 || err "openssl не найден"
command -v "$BC1_NFQWS" >/dev/null 2>&1 || err "$BC1_NFQWS не найден"

# Stale lock cleanup — наша диапазон queue 800-831.
if [ -f "$STATE_DIR/.lock" ]; then
  other=$(cat "$STATE_DIR/.lock" 2>/dev/null)
  if [ -n "$other" ] && kill -0 "$other" 2>/dev/null; then
    err "another blockcheck1 job is already running (pid=$other)"
  fi
  rm -f "$STATE_DIR/.lock"
  for q in $(seq "$BC1_QUEUE_BASE" $((BC1_QUEUE_BASE + 31))); do
    ps -o pid,args 2>/dev/null | awk -v q="$q" '
      $0 ~ ("--qnum[= ]" q "([^0-9]|$)") { print $1 }
    ' | while IFS= read -r pid; do
      [ -n "$pid" ] && kill -TERM "$pid" 2>/dev/null
    done
  done
fi

job_id="$(date +%s)-$$"
job_dir="$STATE_DIR/$job_id"
mkdir -p "$job_dir" || err "cannot mkdir job dir"

dom_file="$job_dir/domains.txt"
printf '%s' "$domains_b64" | base64 -d > "$dom_file" 2>/dev/null
[ -s "$dom_file" ] || err "failed to decode domains_b64 or it is empty"

strat_file="$job_dir/strategies.list"
cgi_log="$job_dir/log.ndjson"

SETSID=$(command -v setsid 2>/dev/null)
[ -n "$SETSID" ] || err "setsid не найден (util-linux отсутствует)"

case "$level" in
  quick|basic|medium|extended|full) ;;
  *[!0-9]*|'') level=basic ;;
esac
[ "$fakebin" = "1" ] || fakebin=0

case "$hard_min_kb" in ''|*[!0-9]*) hard_min_kb=16 ;; esac
[ "$hard_min_kb" -lt 4   ] && hard_min_kb=4
[ "$hard_min_kb" -gt 256 ] && hard_min_kb=256
hard_min_bytes=$((hard_min_kb * 1024))

case "$rnd_repeats" in ''|*[!0-9]*) rnd_repeats=2 ;; esac
[ "$rnd_repeats" -lt 1 ] && rnd_repeats=1
[ "$rnd_repeats" -gt 5 ] && rnd_repeats=5

gen_args="--level=$level"
[ "$fakebin" = "1" ] && [ -d /zapret-fakebin ] && gen_args="$gen_args --fakebin-dir=/zapret-fakebin"
include=""
case ",$tests," in *,http,*)  include="${include:+$include,}http"  ;; esac
case ",$tests," in *,tls12,*) include="${include:+$include,}tls12" ;; esac
case ",$tests," in *,tls13,*) include="${include:+$include,}tls13" ;; esac
case ",$tests," in *,quic,*)  include="${include:+$include,}quic"  ;; esac
[ -n "$include" ] && gen_args="$gen_args --include=$include"

# Кеш gen-strategies удалён: пользователь хочет видеть свежую генерацию при
# каждом запуске. Стоимость регенерации — 5-10s CPU на extended+fakebin,
# приемлемо.

printf 'preparing\n' > "$job_dir/status"

prep_script="$job_dir/_prep.sh"
cat > "$prep_script" <<'PREP_EOF'
#!/bin/sh
_emit() {
  _t=$1; shift
  _ts=$(date +%s)
  _extra=""
  for _kv in "$@"; do
    _k=${_kv%%=*}
    _v=${_kv#*=}
    _v=$(printf '%s' "$_v" | sed 's/\\/\\\\/g; s/"/\\"/g')
    _extra="$_extra,\"$_k\":\"$_v\""
  done
  printf '{"ts":%s,"type":"%s"%s}\n' "$_ts" "$_t" "$_extra" >> "$CGI_LOG"
}

if [ -n "$STRATS_B64" ]; then
  printf '%s' "$STRATS_B64" | base64 -d > "$STRAT_FILE" 2>/dev/null
  if [ ! -s "$STRAT_FILE" ]; then
    _emit error "msg=failed to decode strategies_b64"
    printf 'error\n' > "$STATUS_FILE"
    exit 1
  fi
else
  _emit generating "level=$GEN_LEVEL" "fakebin=$GEN_FAKEBIN" "include=$GEN_INCLUDE"
  if [ -f "$BC_DIR/gen-strategies" ]; then
    sh "$BC_DIR/gen-strategies" $GEN_ARGS > "$STRAT_FILE" 2>/dev/null
  fi
  if [ ! -s "$STRAT_FILE" ] && [ -s "$BC_DIR/strategies.list" ]; then
    cp "$BC_DIR/strategies.list" "$STRAT_FILE"
  fi
  _count=$(wc -l < "$STRAT_FILE" 2>/dev/null | tr -d ' ')
  _emit generated "count=$_count"
fi

if [ ! -s "$STRAT_FILE" ]; then
  _emit error "msg=пустой список стратегий"
  printf 'error\n' > "$STATUS_FILE"
  exit 1
fi

# Runner reused from /www/blockcheck2/run; всё разделение по BC_* env vars,
# которые lib.sh подбирает через ${BC_X:-default}.
exec env \
  BC_STATE_DIR="$BC_STATE_DIR" \
  BC_NFT_TABLE="$BC_NFT_TABLE" \
  BC_QUEUE_BASE="$BC_QUEUE_BASE" \
  BC_MARK_BASE="$BC_MARK_BASE" \
  BC_SPORT_BASE="$BC_SPORT_BASE" \
  BC_NFQWS="$BC_NFQWS" \
  BC_HARD_MIN_BYTES="$BC_HARD_MIN_BYTES" \
  BC_PROBE_RND_REPEATS="$BC_PROBE_RND_REPEATS" \
  BC_QUIC_DEFAULT="$BC_QUIC_DEFAULT" \
  sh "$BC_RUN_DIR/run" \
    --job="$JOB_ID" \
    --workers="$WORKERS" \
    --domains="$DOM_FILE" \
    --tests="$TESTS" \
    --strategies="$STRAT_FILE"
PREP_EOF

JOB_ID="$job_id" \
WORKERS="$workers" \
TESTS="$tests" \
DOM_FILE="$dom_file" \
STRAT_FILE="$strat_file" \
STATUS_FILE="$job_dir/status" \
CGI_LOG="$cgi_log" \
BC_DIR="$BC_DIR" \
BC_RUN_DIR="$BC_RUN_DIR" \
STRATS_B64="$strats_b64" \
GEN_LEVEL="$level" \
GEN_FAKEBIN="$fakebin" \
GEN_INCLUDE="$include" \
GEN_ARGS="$gen_args" \
BC_STATE_DIR="$STATE_DIR" \
BC_NFT_TABLE="$BC1_NFT_TABLE" \
BC_QUEUE_BASE="$BC1_QUEUE_BASE" \
BC_MARK_BASE="$BC1_MARK_BASE" \
BC_SPORT_BASE="$BC1_SPORT_BASE" \
BC_NFQWS="$BC1_NFQWS" \
BC_HARD_MIN_BYTES="$hard_min_bytes" \
BC_PROBE_RND_REPEATS="$rnd_repeats" \
BC_QUIC_DEFAULT="--filter-udp=0-65535 --dpi-desync=fake --dpi-desync-repeats=20" \
  nohup "$SETSID" sh "$prep_script" >>"$job_dir/runner.log" 2>&1 </dev/null &

printf '{"ok":true,"job_id":"%s"}\n' "$job_id"
