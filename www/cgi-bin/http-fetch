#!/bin/sh
echo "Content-Type: application/json; charset=utf-8"
echo ""

b64() {
  base64 -w0 2>/dev/null || base64 | tr -d '\n'
}

json_error() {
  msg="$1"
  code="$2"
  [ -z "$code" ] && code=0
  printf '{"ok":false,"status":%s,"error_b64":"%s"}\n' "$code" "$(printf '%s' "$msg" | b64)"
}

urldecode() {
  printf '%s\n' "$1" | sed 's/+/ /g; s/%\([0-9A-Fa-f][0-9A-Fa-f]\)/\\\x\1/g' | while IFS= read -r line; do printf '%b' "$line"; done
}

field() {
  printf '%s' "$body" | awk -v k="$1" -F'&' '{
    for (i=1; i<=NF; i++) {
      n = index($i, "=")
      if (n > 0 && substr($i, 1, n-1) == k) { print substr($i, n+1); exit }
    }
  }'
}

if [ "$REQUEST_METHOD" != "POST" ]; then
  json_error "POST required" 0
  exit 0
fi

case "$CONTENT_LENGTH" in
  ''|*[!0-9]*) CONTENT_LENGTH=0 ;;
esac
if [ "$CONTENT_LENGTH" -gt 65536 ]; then
  json_error "request body too large" 0
  exit 0
fi

# Read the whole request body. `head -c` loops until N bytes (or EOF), unlike
# `dd bs=N count=1` (single read, can short-read a pipe) or `dd bs=1` (one
# syscall per byte — the old ~minute-long read).
body=$(head -c "$CONTENT_LENGTH")

url=$(urldecode "$(field url)")
method=$(urldecode "$(field method)")
headers=$(urldecode "$(field headers)")
data=$(urldecode "$(field data)")

case "$method" in
  POST) method=POST ;;
  *) method=GET ;;
esac

case "$url" in
  http://*|https://*) ;;
  *) json_error "only http:// or https:// URLs are allowed" 0; exit 0 ;;
esac

# Reject control chars / shell metacharacters in the URL itself.
case "$url" in
  *[\ \"\'\`\<\>\|\{\}\\^]*) json_error "invalid URL characters" 0; exit 0 ;;
esac

# Build argument list without arrays: split headers on newlines only.
set -f
oldifs=$IFS
IFS='
'

out="/dev/shm/http-fetch.$$"
err="/dev/shm/http-fetch.err.$$"
rm -f "$out" "$err"

if command -v curl >/dev/null 2>&1; then
  # -o writes the body straight to a file, -w prints only the status code.
  # We never load the (potentially large) response into a shell variable,
  # and base64 reads the file directly — no double sed, no string round-trips.
  set -- -sS -L -m 25 -X "$method" -o "$out" -w '%{http_code}'
  for h in $headers; do
    [ -z "$h" ] && continue
    set -- "$@" -H "$h"
  done
  if [ "$method" = "POST" ]; then
    set -- "$@" --data-binary "$data"
  fi
  IFS=$oldifs
  status=$(curl "$@" "$url" 2>"$err")
  rc=$?
elif command -v wget >/dev/null 2>&1; then
  set -- -q -T 25 -O "$out"
  for h in $headers; do
    [ -z "$h" ] && continue
    set -- "$@" --header="$h"
  done
  if [ "$method" = "POST" ]; then
    set -- "$@" --post-data="$data"
  fi
  IFS=$oldifs
  wget "$@" "$url" 2>"$err"
  rc=$?
  if [ "$rc" -eq 0 ] && [ -s "$out" ]; then status=200; else status=0; fi
else
  IFS=$oldifs
  set +f
  rm -f "$out" "$err"
  json_error "curl or wget not found" 0
  exit 0
fi

set +f
case "$status" in
  ''|*[!0-9]*) status=0 ;;
esac

if [ -s "$out" ]; then
  payload_b64=$(b64 < "$out")
else
  payload_b64=$(b64 < "$err")
fi
rm -f "$out" "$err"

if [ "$rc" -eq 0 ] && [ "$status" -ge 200 ] 2>/dev/null && [ "$status" -lt 300 ] 2>/dev/null; then
  printf '{"ok":true,"status":%s,"output_b64":"%s"}\n' "$status" "$payload_b64"
else
  printf '{"ok":false,"status":%s,"output_b64":"%s"}\n' "$status" "$payload_b64"
fi
