#!/bin/sh
echo "Content-Type: application/json; charset=utf-8"
echo ""

b64() {
  base64 -w0 2>/dev/null || base64 | tr -d '\n'
}

json_error() {
  msg="$1"
  code="$2"
  [ -z "$code" ] && code=0
  printf '{"ok":false,"status":%s,"error_b64":"%s"}\n' "$code" "$(printf '%s' "$msg" | b64)"
}

urldecode() {
  printf '%s\n' "$1" | sed 's/+/ /g; s/%\([0-9A-Fa-f][0-9A-Fa-f]\)/\\\x\1/g' | while IFS= read -r line; do printf '%b' "$line"; done
}

field() {
  printf '%s' "$body" | awk -v k="$1" -F'&' '{
    for (i=1; i<=NF; i++) {
      n = index($i, "=")
      if (n > 0 && substr($i, 1, n-1) == k) { print substr($i, n+1); exit }
    }
  }'
}

if [ "$REQUEST_METHOD" != "POST" ]; then
  json_error "POST required" 0
  exit 0
fi

case "$CONTENT_LENGTH" in
  ''|*[!0-9]*) CONTENT_LENGTH=0 ;;
esac
if [ "$CONTENT_LENGTH" -gt 65536 ]; then
  json_error "request body too large" 0
  exit 0
fi

body=$(dd bs=1 count="$CONTENT_LENGTH" 2>/dev/null)

url=$(urldecode "$(field url)")
method=$(urldecode "$(field method)")
headers=$(urldecode "$(field headers)")
data=$(urldecode "$(field data)")

case "$method" in
  POST) method=POST ;;
  *) method=GET ;;
esac

case "$url" in
  http://*|https://*) ;;
  *) json_error "only http:// or https:// URLs are allowed" 0; exit 0 ;;
esac

# Reject control chars / shell metacharacters in the URL itself.
case "$url" in
  *[\ \"\'\`\<\>\|\{\}\\^]*) json_error "invalid URL characters" 0; exit 0 ;;
esac

# Build argument list without arrays: split headers on newlines only.
set -f
oldifs=$IFS
IFS='
'

if command -v curl >/dev/null 2>&1; then
  set -- -sS -L -m 25 -X "$method" -w '\n__HTTP_STATUS__:%{http_code}'
  for h in $headers; do
    [ -z "$h" ] && continue
    set -- "$@" -H "$h"
  done
  if [ "$method" = "POST" ]; then
    set -- "$@" --data-binary "$data"
  fi
  IFS=$oldifs
  out=$(curl "$@" "$url" 2>&1)
  rc=$?
  status=$(printf '%s\n' "$out" | sed -n 's/^__HTTP_STATUS__://p' | tail -n 1)
  body_out=$(printf '%s\n' "$out" | sed '/^__HTTP_STATUS__:/d')
elif command -v wget >/dev/null 2>&1; then
  tmp="/tmp/http-fetch.$$"
  set -- -q -T 25 -O "$tmp"
  for h in $headers; do
    [ -z "$h" ] && continue
    set -- "$@" --header="$h"
  done
  if [ "$method" = "POST" ]; then
    set -- "$@" --post-data="$data"
  fi
  IFS=$oldifs
  wget "$@" "$url" >/dev/null 2>&1
  rc=$?
  if [ -s "$tmp" ]; then
    body_out=$(cat "$tmp")
    [ "$rc" -eq 0 ] && status=200
  fi
  rm -f "$tmp"
  [ -z "$status" ] && status=0
else
  IFS=$oldifs
  json_error "curl or wget not found" 0
  exit 0
fi

set +f
[ -z "$status" ] && status=0
payload_b64=$(printf '%s' "$body_out" | b64)
if [ "$rc" -eq 0 ] && [ "$status" -ge 200 ] 2>/dev/null && [ "$status" -lt 300 ] 2>/dev/null; then
  printf '{"ok":true,"status":%s,"output_b64":"%s"}\n' "$status" "$payload_b64"
else
  printf '{"ok":false,"status":%s,"output_b64":"%s"}\n' "$status" "$payload_b64"
fi
