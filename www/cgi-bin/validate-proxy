#!/bin/sh
echo "Content-Type: application/json; charset=utf-8"
echo ""

MIHOMO_BIN="${MIHOMO_BIN:-/usr/local/bin/mihomo}"

if [ "$REQUEST_METHOD" != "POST" ]; then
  printf '{"ok":false,"error_b64":"%s"}\n' "$(printf 'POST required' | base64 -w0 2>/dev/null || printf 'POST required' | base64)"
  exit 0
fi

MAX_BODY=10485760
case "$CONTENT_LENGTH" in
  ''|*[!0-9]*) CONTENT_LENGTH=0 ;;
esac
if [ "$CONTENT_LENGTH" -gt "$MAX_BODY" ]; then
  msg="request body too large"
  printf '{"ok":false,"error_b64":"%s"}\n' "$(printf '%s' "$msg" | base64 -w0 2>/dev/null || printf '%s' "$msg" | base64)"
  exit 0
fi
body=$(head -c "$CONTENT_LENGTH")

b64=$(printf '%s' "$body" | awk -F'&' '{
  for(i=1;i<=NF;i++) {
    if (substr($i,1,4) == "b64=") { print substr($i,5); exit }
  }
}')
b64=$(printf '%s\n' "$b64" | sed 's/+/ /g; s/%\([0-9A-Fa-f][0-9A-Fa-f]\)/\\\x\1/g' | while IFS= read -r line; do printf '%b' "$line"; done)

if [ -z "$b64" ]; then
  printf '{"ok":false,"error_b64":"%s"}\n' "$(printf 'empty body' | base64 -w0 2>/dev/null || printf 'empty body' | base64)"
  exit 0
fi

if [ ! -x "$MIHOMO_BIN" ]; then
  msg="mihomo binary not found at $MIHOMO_BIN"
  printf '{"ok":false,"error_b64":"%s"}\n' "$(printf '%s' "$msg" | base64 -w0 2>/dev/null || printf '%s' "$msg" | base64)"
  exit 0
fi

tmpdir=$(mktemp -d /dev/shm/mihomo-validate.XXXXXX 2>/dev/null) || tmpdir="/dev/shm/mihomo-validate.$$"
mkdir -p "$tmpdir" 2>/dev/null
if [ ! -d "$tmpdir" ]; then
  msg="cannot create tmpdir in /dev/shm"
  printf '{"ok":false,"error_b64":"%s"}\n' "$(printf '%s' "$msg" | base64 -w0 2>/dev/null || printf '%s' "$msg" | base64)"
  exit 0
fi
trap 'rm -rf "$tmpdir"' EXIT

proxy_file="$tmpdir/proxy.yaml"
printf '%s' "$b64" | base64 -d > "$proxy_file" 2>/dev/null
if [ ! -s "$proxy_file" ]; then
  msg="failed to decode base64 body"
  printf '{"ok":false,"error_b64":"%s"}\n' "$(printf 'failed to decode base64 body' | base64 -w0 2>/dev/null || printf 'failed to decode base64 body' | base64)"
  exit 0
fi

# Inline the user's proxies into the test config so `mihomo -t` parses them strictly.
# proxy-providers type:file are loaded lazily and often pass -t with only warnings.
inline_file="$tmpdir/inline.yaml"
first_real=$(awk '!/^[[:space:]]*$/ && !/^[[:space:]]*#/ {print; exit}' "$proxy_file")
case "$first_real" in
  proxies:*)
    cp "$proxy_file" "$inline_file"
    ;;
  *)
    {
      printf 'proxies:\n'
      sed 's/^/  /' "$proxy_file"
    } > "$inline_file"
    ;;
esac

# Reject empty proxy lists (mihomo -t may otherwise pass them silently).
if ! grep -Eq '^[[:space:]]*-[[:space:]]' "$inline_file"; then
  msg="no proxies parsed from input"
  printf '{"ok":false,"error_b64":"%s"}\n' "$(printf '%s' "$msg" | base64 -w0 2>/dev/null || printf '%s' "$msg" | base64)"
  exit 0
fi

{
  cat <<'HEAD'
mixed-port: 17891
mode: rule
log-level: silent
HEAD
  cat "$inline_file"
  cat <<'TAIL'
proxy-groups:
  - name: VALIDATE
    type: select
    proxies:
      - DIRECT
rules:
  - MATCH,VALIDATE
TAIL
} > "$tmpdir/config.yaml"

out=$("$MIHOMO_BIN" -t -d "$tmpdir" 2>&1)
rc=$?

# Encode output as base64 — avoids all JSON escaping problems.
out_b64=$(printf '%s' "$out" | base64 -w0 2>/dev/null || printf '%s' "$out" | base64 | tr -d '\n')

if [ "$rc" -eq 0 ]; then
  printf '{"ok":true,"output_b64":"%s"}\n' "$out_b64"
else
  printf '{"ok":false,"output_b64":"%s"}\n' "$out_b64"
fi
