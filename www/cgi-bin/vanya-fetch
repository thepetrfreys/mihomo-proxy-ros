#!/bin/sh
echo "Content-Type: application/json; charset=utf-8"
echo ""

b64() {
  base64 -w0 2>/dev/null || base64 | tr -d '\n'
}

json_error() {
  msg="$1"
  code="$2"
  [ -z "$code" ] && code=0
  printf '{"ok":false,"status":%s,"error_b64":"%s"}\n' "$code" "$(printf '%s' "$msg" | b64)"
}

urldecode() {
  printf '%s\n' "$1" | sed 's/+/ /g; s/%\([0-9A-Fa-f][0-9A-Fa-f]\)/\\\x\1/g' | while IFS= read -r line; do printf '%b' "$line"; done
}

if [ "$REQUEST_METHOD" != "POST" ]; then
  json_error "POST required" 0
  exit 0
fi

case "$CONTENT_LENGTH" in
  ''|*[!0-9]*) CONTENT_LENGTH=0 ;;
esac
if [ "$CONTENT_LENGTH" -gt 4096 ]; then
  json_error "request body too large" 0
  exit 0
fi

body=$(head -c "$CONTENT_LENGTH")
url_raw=$(printf '%s' "$body" | awk -F'&' '{
  for (i=1; i<=NF; i++) {
    if (substr($i,1,4) == "url=") { print substr($i,5); exit }
  }
}')
url=$(urldecode "$url_raw")

case "$url" in
  https://*) ;;
  *) json_error "only https:// URLs are allowed" 0; exit 0 ;;
esac

rest=${url#https://}
hostport=${rest%%/*}
path=/${rest#*/}

case "$hostport" in
  ''|*[!A-Za-z0-9.:-]*) json_error "invalid host" 0; exit 0 ;;
esac

case "$path" in
  /vanya/*) ;;
  *) json_error "only /vanya/<token> endpoint is allowed" 0; exit 0 ;;
esac

case "$url" in
  *[\ \"\'\`\<\>\|\{\}\\^]*) json_error "invalid URL characters" 0; exit 0 ;;
esac

if command -v curl >/dev/null 2>&1; then
  out=$(curl -sS -L -m 20 -H 'Product-Code: VANYA' -A 'VanyaVPN/1.0' -w '\n__HTTP_STATUS__:%{http_code}' "$url" 2>&1)
  rc=$?
  status=$(printf '%s\n' "$out" | sed -n 's/^__HTTP_STATUS__://p' | tail -n 1)
  body_out=$(printf '%s\n' "$out" | sed '/^__HTTP_STATUS__:/d')
elif command -v wget >/dev/null 2>&1; then
  tmp="/tmp/vanya-fetch.$$"
  body_out=$(wget -q -T 20 -O "$tmp" --header='Product-Code: VANYA' --user-agent='VanyaVPN/1.0' "$url" 2>&1)
  rc=$?
  if [ -s "$tmp" ]; then
    body_out=$(cat "$tmp")
    [ "$rc" -eq 0 ] && status=200
  fi
  rm -f "$tmp"
  [ -z "$status" ] && status=0
else
  json_error "curl or wget not found" 0
  exit 0
fi

[ -z "$status" ] && status=0
payload_b64=$(printf '%s' "$body_out" | b64)
if [ "$rc" -eq 0 ] && [ "$status" -ge 200 ] 2>/dev/null && [ "$status" -lt 300 ] 2>/dev/null; then
  printf '{"ok":true,"status":%s,"output_b64":"%s"}\n' "$status" "$payload_b64"
else
  printf '{"ok":false,"status":%s,"output_b64":"%s"}\n' "$status" "$payload_b64"
fi
